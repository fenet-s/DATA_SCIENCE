import math

def is_prime(n: int) -> bool:
    """
    Checks if a number is prime using an optimized O(sqrt(n)) approach.
    Useful for filtering datasets or basic number theory in DS.
    """
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    
    # Optimization: Only check up to the square root
    for i in range(3, int(math.sqrt(n)) + 1, 2):
        if n % i == 0:
            return False
    return True 

# Example execution
num = 26
print(f"Is {num} prime? {is_prime(num)}")
