def generate_fibonacci(n_terms: int) -> list:
    """
    Generates a Fibonacci sequence of length n_terms.
    Demonstrates list manipulation and iterative logic.
    """
    if n_terms <= 0:
        return []
    elif n_terms == 1:
        return [0]
    
    sequence = [0, 1]
    while len(sequence) < n_terms:
        # DS Tip: Using list indexing to access previous elements
        next_val = sequence[-1] + sequence[-2]
        sequence.append(next_val)
        
    return sequence

# Example execution
print(f"Fibonacci Sequence (10 terms): {generate_fibonacci(10)}")
